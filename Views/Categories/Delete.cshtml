@model webshop_owp.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="row mt-4 mb-5">
    <div class="col-md-6 offset-3">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-danger text-white py-3 text-center">
                <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Delete Category</h4>
            </div>
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h3 class="fw-bold"><i class="bi bi-folder-x fs-1 text-danger d-block mb-3"></i> @Model.Name</h3>
                    <p class="text-muted">Are you sure you want to delete this category? All products in this category will remain, but their category link will be broken.</p>
                </div>

                <div class="bg-light p-3 rounded-3 mb-4">
                    <div class="small mb-1 text-uppercase fw-bold text-muted">Description</div>
                    <div class="mb-0">@Model.Description</div>
                </div>

                <div class="form-group d-flex justify-content-between mt-4">
                    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Cancel</a>
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-5 shadow-sm"><i class="bi bi-trash"></i> Confirm Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
