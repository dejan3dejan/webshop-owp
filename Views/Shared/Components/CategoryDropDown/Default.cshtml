@model IEnumerable<webshop_owp.Models.Category>

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-tags"></i> Categories
    </a>
    <ul class="dropdown-menu shadow" aria-labelledby="navbarDropdown">
        @foreach (var category in Model)
        {
            <li>
                <a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-categoryId="@category.Id">
                    @category.Name
                </a>
            </li>
        }
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item fw-bold" asp-controller="Products" asp-action="Index">All Products</a></li>
    </ul>
</li>
