@{
    ViewData["Title"] = "Order Completed";
}

<div class="row mt-5">
    <div class="col-md-6 offset-3 text-center">
        <div class="card shadow-sm border-0 rounded-3 p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            </div>
            <h1 class="display-5 fw-bold text-dark mb-3">Thank You for Your Order!</h1>
            <p class="lead text-muted mb-4">Your order has been placed successfully and is being processed. You will receive a confirmation email shortly.</p>
            
            <div class="bg-light p-3 rounded-3 mb-4">
                <p class="mb-0 small text-muted">You can track your order status in your profile history.</p>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg px-4 me-md-2">
                    <i class="bi bi-bag"></i> Continue Shopping
                </a>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="bi bi-file-earmark-text"></i> View My Orders
                </a>
            </div>
        </div>
    </div>
</div>
