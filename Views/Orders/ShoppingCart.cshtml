@using webshop_owp.Data.ViewModels;
@model ShoppingCartVM

@{
    ViewData["Title"] = "Shopping cart summary";
}

<div class="row mt-4">
    <div class="col-md-8 offset-2">
        <div class="card shadow-sm border-0 rounded-3 p-4">
            <h2 class="fw-bold mb-4"><i class="bi bi-cart3"></i> Your Shopping Cart</h2>

            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ShoppingCart.GetShoppingCartItems())
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@item.Product.ImageUrl" style="width: 50px; height: 50px; object-fit: contain;" class="me-3" alt="@item.Product.Name">
                                    <span class="fw-bold">@item.Product.Name</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a class="btn btn-outline-secondary" asp-controller="Orders" asp-action="RemoveFromShoppingCart" asp-route-id="@item.Product.Id">-</a>
                                    <span class="btn btn-light disabled fw-bold" style="width: 40px;">@item.Amount</span>
                                    <a class="btn btn-outline-secondary" asp-controller="Orders" asp-action="AddToShoppingCart" asp-route-id="@item.Product.Id">+</a>
                                </div>
                            </td>
                            <td class="text-end">@item.Product.Price.ToString("c")</td>
                            <td class="text-end fw-bold">@((item.Amount * item.Product.Price).ToString("c"))</td>
                            <td class="text-end">
                                <a class="text-danger fs-5" asp-controller="Orders" asp-action="RemoveFromShoppingCart" asp-route-id="@item.Product.Id">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row mt-4 align-items-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="text" id="couponCode" class="form-control" placeholder="Enter coupon code (e.g. TECH10)">
                        <button class="btn btn-outline-primary" type="button" onclick="applyCoupon()">Apply</button>
                    </div>
                    <div id="couponMessage" class="small mt-1"></div>
                </div>
                <div class="col-md-6 text-end">
                    <h4 class="text-muted small mb-1">Order Total:</h4>
                    <h2 class="fw-bold text-primary" id="cartTotal">@Model.ShoppingCartTotal.ToString("c")</h2>
                </div>
            </div>

            <hr class="my-4">

            <div class="d-flex justify-content-between">
                <a class="btn btn-outline-secondary px-4" asp-controller="Products" asp-action="Index">
                    <i class="bi bi-arrow-left"></i> Continue Shopping
                </a>
                @if (Model.ShoppingCart.GetShoppingCartItems().Count > 0)
                {
                    <a class="btn btn-success btn-lg px-5 shadow-sm" asp-action="Checkout">
                        Checkout <i class="bi bi-credit-card ms-2"></i>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function applyCoupon() {
        var code = document.getElementById('couponCode').value;
        $.post('/Orders/ApplyCoupon', { code: code }, function(data) {
            if(data.success) {
                document.getElementById('couponMessage').innerHTML = "<span class='text-success'>Coupon applied! " + data.discount + "% discount.</span>";
                toastr.success("Discount applied!");
                // UI demonstration of discount calculation
                var currentTotalStr = document.getElementById('cartTotal').innerText;
                var currentTotal = parseFloat(currentTotalStr.replace(/[^0-9,.]/g, '').replace(',', '.'));
                var newTotal = currentTotal * (1 - data.discount / 100.0);
                document.getElementById('cartTotal').innerText = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(newTotal);
            } else {
                document.getElementById('couponMessage').innerHTML = "<span class='text-danger'>" + data.message + "</span>";
                toastr.error(data.message);
            }
        });
    }
</script>
