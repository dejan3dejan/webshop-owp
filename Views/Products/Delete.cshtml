@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row mt-4 mb-5">
    <div class="col-md-6 offset-3">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-danger text-white py-3 text-center">
                <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Delete Confirmation</h4>
            </div>
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <img src="@Model.ImageUrl" style="width: 150px; height: 150px; object-fit: contain;" class="mb-3" alt="@Model.Name">
                    <h3 class="fw-bold">@Model.Name</h3>
                    <p class="text-muted">Are you sure you want to delete this product? This action cannot be undone.</p>
                </div>

                <div class="bg-light p-3 rounded-3 mb-4">
                    <div class="row small mb-2 text-uppercase fw-bold text-muted">
                        <div class="col-6 text-start ps-3">Price</div>
                        <div class="col-6 text-end pe-3">Stock</div>
                    </div>
                    <div class="row h5 mb-0">
                        <div class="col-6 text-start ps-3 text-primary fw-bold">@Model.Price.ToString("c")</div>
                        <div class="col-6 text-end pe-3">@Model.StockAmount units</div>
                    </div>
                </div>

                <div class="form-group d-flex justify-content-between mt-4">
                    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Cancel</a>
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-5 shadow-sm"><i class="bi bi-trash"></i> Confirm Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
