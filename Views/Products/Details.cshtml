@model webshop_owp.Models.Product

@{
    ViewData["Title"] = "Details for " + Model.Name;
}

<div class="row mt-4">
    <div class="col-md-10 offset-1">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="row g-0">
                <div class="col-md-5 bg-white p-4 d-flex align-items-center justify-content-center position-relative">
                    <img src="@Model.ImageUrl" class="img-fluid rounded-start" style="max-height: 400px; object-fit: contain;" alt="@Model.Name">
                    @if(Model.StockAmount <= 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 start-0 m-4 fs-6">Out of Stock</span>
                    }
                    @if(Model.DiscountPercentage > 0)
                    {
                        <span class="badge bg-primary position-absolute top-0 end-0 m-4 fs-6">-@Model.DiscountPercentage% OFF</span>
                    }
                </div>
                <div class="col-md-7">
                    <div class="card-body p-5">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb small">
                                <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
                                <li class="breadcrumb-item active" aria-current="page">@Model.Category.Name</li>
                            </ol>
                        </nav>
                        
                        <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>
                        <p class="text-muted mb-4 fs-5">@Model.Description</p>
                        
                        <div class="bg-light p-4 rounded-3 mb-4">
                            @if (Model.DiscountPercentage > 0)
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <h2 class="text-primary fw-bold mb-0">@((Model.Price * (1 - Model.DiscountPercentage / 100.0)).ToString("c"))</h2>
                                    <h4 class="text-muted text-decoration-line-through mb-0">@Model.Price.ToString("c")</h4>
                                </div>
                            }
                            else
                            {
                                <h2 class="text-primary fw-bold mb-0">@Model.Price.ToString("c")</h2>
                            }
                            
                            @if (Model.StockAmount > 0)
                            {
                                <p class="text-success mb-0 mt-2 small"><i class="bi bi-check-circle-fill"></i> In stock - @Model.StockAmount units available</p>
                            }
                            else
                            {
                                <p class="text-danger mb-0 mt-2 small"><i class="bi bi-x-circle-fill"></i> Currently unavailable</p>
                            }
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                            @if (Model.StockAmount > 0)
                            {
                                <button class="btn btn-success btn-lg px-5 add-to-cart-btn" data-id="@Model.Id" data-name="@Model.Name">
                                    <i class="bi bi-cart-plus-fill"></i> Add to Cart
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-lg px-5 disabled">
                                    <i class="bi bi-x-circle"></i> Out of Stock
                                </button>
                            }
                            <a class="btn btn-outline-secondary btn-lg px-4" asp-action="Index">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                        </div>
                        
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <hr class="my-4">
                            <div class="d-flex gap-2">
                                <a class="btn btn-sm btn-outline-primary shadow-sm px-3" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil"></i> Edit Product</a>
                                <a class="btn btn-sm btn-outline-danger shadow-sm px-3" asp-action="Delete" asp-route-id="@Model.Id"><i class="bi bi-trash"></i> Delete</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
