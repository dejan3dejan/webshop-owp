@model webshop_owp.Data.ViewModels.NewProductVM

@{
    ViewData["Title"] = "Create a new product";
}

<div class="row mt-4 mb-5">
    <div class="col-md-8 offset-2">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-plus-circle"></i> Create New Product</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Name" class="control-label fw-bold small text-uppercase"></label>
                                <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="Price" class="control-label fw-bold small text-uppercase"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="StockAmount" class="control-label fw-bold small text-uppercase"></label>
                                <input asp-for="StockAmount" type="number" class="form-control" />
                                <span asp-validation-for="StockAmount" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="CategoryId" class="control-label fw-bold small text-uppercase"></label>
                                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories">
                                    <option value="">-- Select Category --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="ImageUrl" class="control-label fw-bold small text-uppercase"></label>
                                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group mb-3">
                                <label asp-for="Description" class="control-label fw-bold small text-uppercase"></label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter product description..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mt-4 d-flex justify-content-between">
                        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back to list</a>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm"><i class="bi bi-check-lg"></i> Create Product</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
