@model IEnumerable<webshop_owp.Models.Product>

@{
    ViewData["Title"] = "Inventory Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold"><i class="bi bi-box-seam"></i> Inventory & Discounts</h1>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Product</th>
                        <th>Category</th>
                        <th class="text-center">Current Stock</th>
                        <th class="text-center">Stock Actions</th>
                        <th class="text-center">Discount %</th>
                        <th class="text-end pe-4">Base Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl" style="width: 40px; height: 40px; object-fit: contain;" class="me-3" alt="">
                                    <span class="fw-bold">@item.Name</span>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark">@item.Category.Name</span></td>
                            <td class="text-center">
                                <span id="stock-@item.Id" class="badge @(item.StockAmount <= 3 ? "bg-danger" : "bg-success") fs-6">
                                    @item.StockAmount
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm shadow-sm">
                                    <button onclick="updateStock(@item.Id, -1)" class="btn btn-outline-danger"><i class="bi bi-dash"></i></button>
                                    <button onclick="updateStock(@item.Id, 1)" class="btn btn-outline-success"><i class="bi bi-plus"></i></button>
                                </div>
                            </td>
                            <td class="text-center" style="width: 150px;">
                                <div class="input-group input-group-sm mx-auto" style="width: 100px;">
                                    <input type="number" class="form-control text-center" value="@item.DiscountPercentage" 
                                           onchange="updateDiscount(@item.Id, this.value)" min="0" max="100">
                                    <span class="input-group-text">%</span>
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <span class="fw-bold">@item.Price.ToString("c")</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateStock(id, amount) {
            $.post('/Admin/UpdateStock', { id: id, amount: amount }, function(data) {
                if (data.success) {
                    var badge = $('#stock-' + id);
                    badge.text(data.newStock);
                    badge.removeClass('bg-success bg-danger');
                    badge.addClass(data.newStock <= 3 ? 'bg-danger' : 'bg-success');
                    toastr.success('Stock updated');
                }
            });
        }

        function updateDiscount(id, discount) {
            $.post('/Admin/UpdateDiscount', { id: id, discount: discount }, function(data) {
                if (data.success) {
                    toastr.success('Discount updated to ' + discount + '%');
                } else {
                    toastr.error('Failed to update discount');
                }
            });
        }
    </script>
}
